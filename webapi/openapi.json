          },
          "docName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Docname"
          },
          "currPage": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Currpage"
          },
          "highlights": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/Highlight"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Highlights"
          },
          "max_words": {
            "type": "integer",
            "title": "Max Words",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "reqRefId",
          "resRefId",
          "prompt"
        ],
        "title": "SummarizeInput",
        "description": "Request body for the summarization endpoint.\n\nExtends :class:`~utils.req_res_structures.BaseRequest` with an optional\nword-count limit.\n\n:param max_words: Soft upper bound on summary length in words.\n    ``0`` (default) means no limit."
      },
