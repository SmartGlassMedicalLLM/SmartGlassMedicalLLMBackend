            "type": "string",
            "title": "Prompt",
            "description": "The natural-language question to answer."
          },
          "sessionId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sessionid",
            "description": "Optional session identifier."
          },
          "userId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Userid",
            "description": "Optional user identifier."
          },
          "docName": {
            "anyOf": [
              {
                "type": "string"
