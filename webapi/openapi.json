          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "APIError",
        "description": "Structured error detail embedded inside :class:`ErrorResponse`.\n\n:param code: Machine-readable error code (such as ``\"VALIDATION_ERROR\"``).\n:param message: Human-readable error description."
      },
      "BaseRequest": {
        "properties": {
          "reqRefId": {
            "type": "string",
            "title": "Reqrefid"
          },
          "resRefId": {
            "type": "string",
            "title": "Resrefid"
          },
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "sessionId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sessionid"
          },
          "userId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Userid"
          },
          "docName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Docname"
          },
