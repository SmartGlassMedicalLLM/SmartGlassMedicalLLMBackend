        "type": "object",
        "required": [
          "refId",
          "page",
          "label",
          "quote",
          "highlightedWord",
          "confidence"
        ],
        "title": "DocumentReference",
        "description": "A document citation supporting a claim in an AI-generated answer.\n\n:param refId: Unique reference identifier (such as ``\"ref-1\"``).\n:param page: 1-indexed page number the quote was taken from.\n:param label: Short human-readable label (such as ``\"Safety profile\"``).\n:param quote: The verbatim excerpt from the document.\n:param highlightedWord: The highlighted word that scoped this reference, if any.\n:param confidence: Similarity score (0-1) between the claim and the quote."
      },
      "ErrorResponse": {
        "properties": {
          "reqRefId": {
            "type": "string",
            "title": "Reqrefid"
          },
          "resRefId": {
            "type": "string",
            "title": "Resrefid"
          },
