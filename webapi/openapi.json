            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Currpage"
          },
          "highlights": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/Highlight"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Highlights"
          }
        },
        "type": "object",
        "required": [
          "reqRefId",
          "resRefId",
          "prompt"
        ],
        "title": "BaseRequest",
        "description": "Common request shared by all endpoints.\n\n:param reqRefId: Client-assigned request correlation ID.\n:param resRefId: Client-assigned response correlation ID.\n:param prompt: The natural-language prompt or text to process.\n:param sessionId: Optional session identifier for stateful interactions.\n:param userId: Optional user identifier for analytics.\n:param docName: Optional name of the document being queried.\n:param currPage: Optional 1-indexed current page number in the viewed document.\n:param highlights: Optional list of highlighted terms and their page locations."
      },
      "BaseResponse": {
        "properties": {
          "reqRefId": {
            "type": "string",
            "title": "Reqrefid"
          },
          "resRefId": {
            "type": "string",
            "title": "Resrefid"
          },
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "references": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/DocumentReference"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "References"
          }
        },
        "type": "object",
        "required": [
          "reqRefId",
          "resRefId",
          "answer"
        ],
        "title": "BaseResponse",
        "description": "Standard success response envelope.\n\n:param reqRefId: Echoed from the request for correlation.\n:param resRefId: Echoed from the request for correlation.\n:param answer: The model's answer or generated text.\n:param references: Optional list of document citations supporting the answer."
      },
      "Body_prompt_base_form_data_advanced_query_post": {
